    "/api/v1/chat/sessions": {
      "post": {
        "summary": "대화 세션 생성",
        "deprecated": false,
        "description": "새 AI 챗봇 대화 세션을 생성합니다.\n\n### 세션이란?\n대화 이력을 유지하는 단위입니다. 하나의 세션 안에서 대화가 이어지며, 새 주제는 새 세션을 생성합니다.\n\n### 테스트 시나리오:\n  1. 정상 요청 (유효한 guest_id + persona) → 200 OK\n  2. 존재하지 않는 persona → 400 Bad Request\n  3. guest_id 누락 → 422 Unprocessable Entity",
        "tags": [],
        "parameters": [
          {
            "name": "Content-Type",
            "in": "header",
            "description": "",
            "required": false,
            "example": "application/json",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Cookie",
            "in": "header",
            "description": "Spring 세션 쿠키 (guest_id 추출용)",
            "required": false,
            "example": "{{cookie}}",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {}
              },
              "example": {
                "guest_id": "guest_c8812f49-54b7-4858-85e6-65f98b4a410e",
                "persona": "friendly_pt"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {}
                },
                "example": {
                  "id": 1,
                  "guest_id": "guest_c8812f49-54b7-4858-85e6-65f98b4a410e",
                  "persona": "friendly_pt",
                  "title": null,
                  "created_at": "2026-04-16T09:00:00Z",
                  "updated_at": "2026-04-16T09:00:00Z"
                }
              }
            },
            "headers": {}
          },
          "400": {
            "description": "존재하지 않는 페르소나",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {}
                },
                "example": {
                  "detail": "Unknown persona: unknown_persona"
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
