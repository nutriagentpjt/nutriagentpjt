# .env.example
# 이 파일을 복사해서 .env 로 만들고 값을 채워주세요.
# cp .env.example .env

# -------------------------------------------------------
# 필수
# -------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/nutriagent

# -------------------------------------------------------
# 앱 설정 (선택 — 기본값 있음)
# -------------------------------------------------------
APP_ENV=dev                    # dev / staging / prod
# APP_NAME=NutriAgent Vision API
# APP_VERSION=0.1.0
# DEBUG=false

# -------------------------------------------------------
# 모델 설정 (선택)
# -------------------------------------------------------
MODEL_DEVICE=cpu               # cpu / cuda / mps
MODEL_WEIGHTS_PATH=            # 비워두면 torch.hub 에서 자동 다운로드 # 오프라인 환경이라면 로컬 .pth 경로를 지정
# MODEL_NAME=dinov2_vitb14

# -------------------------------------------------------
# 검색 설정 (선택)
# -------------------------------------------------------
# DEFAULT_TOP_K=5
# DEFAULT_TOP_CANDIDATES=3
# MAX_TOP_K=20

# -------------------------------------------------------
# 업로드 제한 (선택)
# -------------------------------------------------------
# MAX_UPLOAD_MB=10
