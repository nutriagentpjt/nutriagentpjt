# -------------------------------------------------------
# 이 파일을 복사해서 .env 로 만들고 값을 채워주세요.
# cp .env.example .env
#
# .env 는 git에 커밋하지 않습니다 (.gitignore 적용됨).
# 팀원 각자 이 파일을 기반으로 .env 를 만들어야 합니다.
# -------------------------------------------------------

# PostgreSQL
POSTGRES_USER=nutriagent
POSTGRES_PASSWORD=nutriagent
POSTGRES_DB=nutriagent

# Vision API
APP_ENV=dev                  # dev / staging / prod
MODEL_DEVICE=cpu             # cpu / cuda / mps
MODEL_WEIGHTS_PATH=          # 비워두면 torch.hub 자동 다운로드 (첫 기동 시 ~330MB)
VISION_WORKERS=2             # uvicorn 워커 수 (워커당 DINOv2 ~330MB RAM)
