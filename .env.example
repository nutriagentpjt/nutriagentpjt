# -------------------------------------------------------
# 이 파일을 복사해서 .env 로 만들고 값을 채워주세요.
# cp .env.example .env
#
# .env 는 git에 커밋하지 않습니다 (.gitignore 적용됨).
# 팀원 각자 이 파일을 기반으로 .env 를 만들어야 합니다.
# -------------------------------------------------------

# PostgreSQL (EC2에선 docker-compose 외부에서 분리 운용 중. 로컬 개발 시 별도 기동)
POSTGRES_USER=nutriagent
POSTGRES_PASSWORD=nutriagent
POSTGRES_DB=nutriagent

# Spring ↔ FastAPI 내부 호출 인증 (임의 시크릿 문자열)
INTERNAL_API_KEY=

# AWS Bedrock (FastAPI 챗봇 엔진이 InvokeModel 호출 시 사용)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Vision API (별도 vector-DB 컨테이너로 운영 — 운영 postgres 무손상)
# 운영 postgres와 분리된 자격증명 사용. 두 DB는 schema·data 모두 독립.
VISION_PG_DB=vision
VISION_PG_USER=vision
VISION_PG_PASSWORD=
VISION_APP_ENV=dev               # dev / staging / prod (prod면 MODEL_WEIGHTS_PATH 필수)
VISION_MODEL_DEVICE=cpu          # cpu / cuda / mps
VISION_MODEL_WEIGHTS_PATH=       # 비워두면 torch.hub 자동 다운로드 (첫 기동 시 ~330MB)
VISION_WORKERS=2                 # uvicorn 워커 수 (워커당 DINOv2 ~330MB RAM)
